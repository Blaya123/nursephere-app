{
  "expo": {
    "name": "Nursphere",
    "slug": "nursphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nursphere",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#008751"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nursphere.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#008751"
      },
      "package": "com.nursphere.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a0e73d5b-ff8f-468e-9fe1-962561aaa6eb"
      }
    },
    "owner": "blaya123"
  }
}
